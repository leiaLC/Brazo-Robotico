<?xml version="1.0"?>
<!--
  abb_irb14050.urdf

  ABB IRB 14050 - 7-DOF single arm.
  Kinematics & meshes from:
      MerlinLaboratory/ABB_omnicore_ros_driver (legacy branch)
      robots_description/xacro/YumiSingleArm/single_yumi.xacro

  Generated as plain URDF (no xacro) with all PI/deg expressions
  evaluated. Joint names match the abb_irb14050_egm bridge:
  joint_1..joint_7 in physical order from base to tip.
-->
<robot name="abb_irb14050">

  <material name="Grey"><color rgba="0.5 0.5 0.5 1.0"/></material>

  <!-- World / floor frame -->
  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <!-- Pedestal of the IRB14050 (single arm base mesh) -->
  <link name="base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
      <mass value="2.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/single_arm_base.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/coarse/single_arm_base.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint_1: pedestal -> link_1.
       Merlin: <origin xyz="0 0 0.2048" rpy="0 0 PI"/>
       Limits: ±168.5 deg = ±2.94087978961 rad
       Velocity: 180 deg/s = 3.14159265359 rad/s -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin rpy="0 0 3.14159265359" xyz="0 0 0.2048"/>
    <axis xyz="0 0 1"/>
    <limit effort="300" lower="-2.94087978961" upper="2.94087978961" velocity="3.14159265359"/>
    <dynamics damping="0.5"/>
  </joint>

  <link name="link_1">
    <inertial>
      <origin rpy="0 0 0" xyz="0 -0.03 0.12"/>
      <mass value="2"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/link_1.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/coarse/link_1.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint_2: limits [-143.5, 43.5] deg -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin rpy="1.57079632679 0.0 0.0" xyz="0.03 0.0 0.1"/>
    <axis xyz="0 0 1"/>
    <limit effort="300" lower="-2.50454747661" upper="0.759218224618" velocity="3.14159265359"/>
    <dynamics damping="0.5"/>
  </joint>

  <link name="link_2">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/link_2.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/coarse/link_2.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint_3 (elbow, 7-DOF axis): limits ±168.5 deg -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin rpy="-1.57079632679 0.0 0.0" xyz="-0.03 0.17283 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="300" lower="-2.94087978961" upper="2.94087978961" velocity="3.14159265359"/>
    <dynamics damping="0.5"/>
  </joint>

  <link name="link_3">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/link_3.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/coarse/link_3.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint_4: limits [-123.5, 80] deg -->
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin rpy="1.57079632679 -1.57079632679 0.0" xyz="-0.04188 0.0 0.07873"/>
    <axis xyz="0 0 1"/>
    <limit effort="300" lower="-2.15548162621" upper="1.3962634016" velocity="3.14159265359"/>
    <dynamics damping="0.5"/>
  </joint>

  <link name="link_4">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/link_4.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/coarse/link_4.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint_5: limits ±290 deg, velocity 400 deg/s -->
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin rpy="-1.57079632679 0.0 0.0" xyz="0.0405 0.16461 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="300" lower="-5.06145483078" upper="5.06145483078" velocity="6.98131700798"/>
    <dynamics damping="0.5"/>
  </joint>

  <link name="link_5">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/link_5.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/coarse/link_5.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint_6: limits [-88, 138] deg, velocity 400 deg/s -->
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin rpy="1.57079632679 0.0 0.0" xyz="-0.027 0 0.10039"/>
    <axis xyz="0 0 1"/>
    <limit effort="300" lower="-1.53588974176" upper="2.40855436775" velocity="6.98131700798"/>
    <dynamics damping="0.5"/>
  </joint>

  <link name="link_6">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/link_6.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/coarse/link_6.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint_7: limits ±229 deg, velocity 400 deg/s -->
  <joint name="joint_7" type="revolute">
    <parent link="link_6"/>
    <child link="link_7"/>
    <origin rpy="-1.57079632679 0.0 0.0" xyz="0.027 0.029 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="300" lower="-3.99680398707" upper="3.99680398707" velocity="6.98131700798"/>
    <dynamics damping="0.5"/>
  </joint>

  <link name="link_7">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/link_7.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://abb_irb14050_description/meshes/coarse/link_7.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- TCP / tool0 reference frame for MoveIt -->
  <joint name="tool0_joint" type="fixed">
    <parent link="link_7"/>
    <child link="tool0"/>
    <origin rpy="0 0 0" xyz="0 0 0.007"/>
  </joint>

  <link name="tool0"/>
<ros2_control name="abb_irb14050_system" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
    </hardware>
    <joint name="joint_1">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_2">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_3">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_4">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_5">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_6">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_7">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
</robot>
